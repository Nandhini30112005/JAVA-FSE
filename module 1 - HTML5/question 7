<!DOCTYPE html>
<html>
<head>
    <title>Video Invite</title>
</head>
<body>

<video width="400" controls oncanplay="videoReady()">
    <source src="video.mp4" type="video/mp4">
</video>

<p id="message"></p>

<script>
function videoReady() {
    document.getElementById("message").innerHTML = "Video ready to play";
}

window.onbeforeunload = function() {
    return "Leave page?";
}
</script>

</body>
</html>

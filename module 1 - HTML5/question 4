<!DOCTYPE html>
<html>
<head>
    <title>Image Gallery</title>

    <style>
        img {
            border: 2px solid black;
            width: 150px;
            height: 150px;
        }
    </style>
</head>
<body>

<table>
    <caption>Community Events</caption>

    <tr>
        <td>
            <img src="image1.jpg" alt="Event1" title="Music Event">
        </td>

        <td>
            <img src="image2.jpg" alt="Event2" title="Dance Event">
        </td>

        <td>
            <img src="image3.jpg" alt="Event3" title="Food Event">
        </td>
    </tr>

    <tr>
        <td>Music</td>
        <td>Dance</td>
        <td>Food</td>
    </tr>
</table>

</body>
</html>

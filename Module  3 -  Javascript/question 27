import java.util.ArrayList;
import java.util.Collections;
import java.util.List;

public class LambdaExpression {

    public static void main(String[] args) {

        List<String> list =
                new ArrayList<>();

        list.add("Java");
        list.add("Python");
        list.add("C");
        list.add("HTML");

        Collections.sort(
                list,
                (a,b) -> a.compareTo(b));

        System.out.println(list);
    }
}

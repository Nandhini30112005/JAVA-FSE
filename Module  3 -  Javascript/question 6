public class DataTypeDemo {
    public static void main(String[] args) {

        int a = 100;
        float b = 10.5f;
        double c = 25.456;
        char d = 'A';
        boolean e = true;

        System.out.println("Integer : " + a);
        System.out.println("Float : " + b);
        System.out.println("Double : " + c);
        System.out.println("Character : " + d);
        System.out.println("Boolean : " + e);
    }
}
